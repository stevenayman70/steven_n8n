    {
      "parameters": {
        "jsCode": "// Get used amounts from Code Node 1\nconst used = $('Code in JavaScript1').first().json;\nconst burgerUsed = used.burgerUsed;\nconst bunsUsed = used.bunsUsed;\nconst cheeseUsed = used.cheeseUsed;\n\n// Process each row from Google Sheets\nconst rows = $input.all();\nconst result = [];\n\nfor (const row of rows) {\n  const item = row.json.Item;\n  const currentStock = Number(row.json.Number);\n  let newStock = currentStock;\n\n  if (item === 'Burger') {\n    newStock = currentStock - burgerUsed;\n  } else if (item === 'Cheese') {\n    newStock = currentStock - cheeseUsed;\n  } else if (item === 'Bun') {\n    newStock = currentStock - bunsUsed;\n  }\n\n  result.push({ json: { Item: item, Number: newStock } });\n}\n\nreturn result;\n"
      },
