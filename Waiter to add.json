    {
      "parameters": {
        "jsCode": "const message = $input.first().json.message.text;\n\nconst items = message.split(' ');\nconst inventory = {};\n\nfor (const item of items) {\n  const [name, quantity] = item.split(':');\n  if (name && quantity) {\n    inventory[name.trim().toLowerCase()] = parseInt(quantity.trim());\n  }\n}\n\nreturn [\n  { json: { item: 'Burger', number: inventory['burger'] || 0 } },\n  { json: { item: 'Cheese', number: inventory['cheese'] || 0 } },\n  { json: { item: 'Bun', number: inventory['bun'] || 0 } }\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
