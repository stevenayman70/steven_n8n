    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst lowItems = items.filter(row => Number(row.json.Number) <= 0);\n\nif (lowItems.length === 0) {\n  return [{ json: { hasAlert: false, message: 'some one ordered' } }];\n}\n\nconst names = lowItems.map(row => row.json.Item).join(', ');\nconst message = `⚠️ Stock Alert! Out of stock: ${names}. Please restock!`;\n\nreturn [{ json: { hasAlert: true, message: message } }];\n"
      },
