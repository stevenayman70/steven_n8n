    {
      "parameters": {
        "jsCode": "const formData = $input.first().json;\n\nconst orderArray = formData[\"What Is the Order\"] || [];\nconst burgerType = Array.isArray(orderArray) ? orderArray[0] : orderArray;\n\n// Find sandwich quantity key dynamically\nconst qtyKey = Object.keys(formData).find(k => k !== \"What Is the Order\" && k !== \"submittedAt\" && k !== \"formMode\");\nconst quantity = formData[qtyKey] || 1;\n\nlet burgerUsed = 0;\nlet bunsUsed = 0;\nlet cheeseUsed = 0;\n\nif (burgerType && String(burgerType).toLowerCase().includes('cheese')) {\n  burgerUsed = 1 * quantity;\n  bunsUsed = 2 * quantity;\n  cheeseUsed = 1 * quantity;\n} else {\n  burgerUsed = 1 * quantity;\n  bunsUsed = 2 * quantity;\n  cheeseUsed = 0;\n}\n\nreturn [{ json: { burgerUsed, bunsUsed, cheeseUsed, burgerType, quantity } }];\n"
      },
