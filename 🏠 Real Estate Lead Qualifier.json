    {
      "parameters": {
        "jsCode": "const output = $input.first().json.output || '';\n\n// Look for the [LEAD_DATA] marker with JSON\nconst match = output.match(/\\[LEAD_DATA\\](\\{.*?\\})/);\n\nif (!match) {\n  // Conversation still in progress\n  return [{ json: { complete: false, output: output } }];\n}\n\ntry {\n  const leadData = JSON.parse(match[1]);\n  const score = leadData.score || 0;\n  \n  let leadStatus;\n  if (score >= 80) leadStatus = '🔥 HOT LEAD';\n  else if (score >= 50) leadStatus = '⚡ WARM LEAD';\n  else leadStatus = '❄️ COLD LEAD';\n  \n  return [{\n    json: {\n      complete: true,\n      name: leadData.name || '',\n      phone: leadData.phone || '',\n      property_type: leadData.property_type || '',\n      buy_or_rent: leadData.buy_or_rent || '',\n      new_or_resale: leadData.new_or_resale || '',\n      first_purchase: leadData.first_purchase || '',\n      timeline: leadData.timeline || '',\n      budget: leadData.budget || '',\n      raw_score: leadData.raw_score || 0,\n      score: score,\n      lead_status: leadStatus,\n      is_hot_lead: score >= 80,\n      output: output\n    }\n  }];\n} catch (e) {\n  return [{ json: { complete: false, output: output, parseError: e.message } }];\n}"
      },
