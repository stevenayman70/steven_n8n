    {
      "parameters": {
        "jsCode": "const output = $input.item.json.output;\n\n// Extract JSON between the flags\nconst match = output.match(/##ORDER_DONE##([\\s\\S]*?)##END##/);\nconst order = JSON.parse(match[1].trim());\n\n// Clean the reply (remove the flag block from customer message)\nconst cleanReply = output.replace(/##ORDER_DONE##[\\s\\S]*?##END##/, '').trim();\n\nreturn {\n  cleanReply,\n  items: order.items,\n  total: order.total,\n  phone: order.phone,\n  address: order.address,\n  timestamp: new Date().toLocaleString('en-EG', { timeZone: 'Africa/Cairo' })\n};"
      },
