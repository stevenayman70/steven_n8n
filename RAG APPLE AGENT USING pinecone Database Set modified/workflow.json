    {
      "parameters": {
        "jsCode": "const allItems = $input.all();\n\n// Search results have lowercase \"id\" and \"name\"\nconst searchResults = allItems.filter(item => item.json.id !== undefined && item.json.name !== undefined);\n\n// Sheet rows have uppercase \"Id\" and \"Name\"\nconst sheetRows = allItems.filter(item => item.json.Id !== undefined && item.json.Name !== undefined);\n\nconsole.log(\"Search results count:\", searchResults.length);\nconsole.log(\"Sheet rows count:\", sheetRows.length);\n\n// ── BUILD LOOKUP SETS FROM SHEET ──────────────────────────────────────────────\nconst sheetIds = new Set(\n  sheetRows.map(r => r.json.Id?.trim()).filter(Boolean)\n);\nconst sheetNames = new Set(\n  sheetRows.map(r => r.json.Name?.trim()).filter(Boolean)\n);\n\nconsole.log(\"Sheet IDs:\", [...sheetIds]);\n\n// ── FIND FILES NOT IN SHEET ───────────────────────────────────────────────────\nconst missing = searchResults.filter(file => {\n  const id   = file.json.id?.trim();\n  const name = file.json.name?.trim();\n  return !sheetIds.has(id) || !sheetNames.has(name);\n});\n\n// ── OUTPUT ────────────────────────────────────────────────────────────────────\nif (missing.length === 0) {\n  return [{ json: { status: \"All items found in sheet\", missing: [] } }];\n}\n\nreturn missing.map(file => ({\n  json: {\n    status: \"NOT FOUND in sheet\",\n    id:   file.json.id,\n    name: file.json.name,\n  }\n}));"
      },
